# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
APP_NAME=PrabhuTechPro

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Provider: Gmail (recommended)
# Steps:
#   1. Enable 2-Factor Auth: myaccount.google.com → Security
#   2. Generate App Password: Security → App Passwords → Mail
#   3. Paste the 16-char password below (no spaces)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# The inbox that receives all contact form submissions
CONTACT_RECEIVER=your-email@gmail.com

# "From" display name shown in received emails
SMTP_FROM_NAME=Prabhu Tech Pro
